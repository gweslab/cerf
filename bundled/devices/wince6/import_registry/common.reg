   "ReadSectorTimeout"=dword:2710  ; Read sector timeout (10 s)
   "WriteSectorTimeout"=dword:2710 ; Read sector timeout (10 s)
   "ScsiCommandTimeout"=dword:1388 ; Command timeout (5 s)
