; @CESYSGEN IF ATAPI_ATAPI_PCMCIA

; TransferMode Key
;   PIO default mode                0x00
;   PIO default mode, disable IORDY 0x01
;   PIO flow control transfer mode  0x08 (mode 0), 0x09 (mode 1), 0x0A (mode 2), 0x0B (mode 3), 0x0C (mode 4)
;   Multiword DMA mode              0x20 (mode 0), 0x21 (mode 1), 0x22 (mode 2)
;   Ultra DMA mode                  0x40 (mode 0), 0x41 (mode 1), 0x42 (mode 2), 0x43 (mode 3), 0x44 (mode 4), ...
;   Default                         0xFF

[HKEY_LOCAL_MACHINE\Drivers\PCCARD\PCMCIA\TEMPLATE\ATADISKA]
    "FUNCTION_ID"=dword:4
    "IoBase"=multi_sz:"1f0","3f6"
    "IoLen"=multi_sz:"8","2"
    "IOADDR_HIGHESTBIT_SET"=dword:1 ; Alter the address to highest locate to avoiding conflict with IDE Controller
    "Prefix"="IDE"
    "Dll"="atapi.dll"
    "Order"=dword:6
    "Legacy"=dword:00               ; not legacy
;   "Irq"=dword:00                  ; provided by PC Card bus driver
;   "SysIntr"=dword:00              ; provided by PC Card bus driver
;   "DMAAlignment"=dword:00         ; default DMA alignment; DMA not supported
    "SoftResetTimeout"=dword:03     ; ATA/ATAPI spec defines 31s ceiling; this is too long
    "StatusPollCycles"=dword:100    ; Status register DRQ/BSY polling; 256 poll cycles
    "StatusPollsPerCycle"=dword:20  ; Status register DRQ/BSY polling; 32 polls per cycle
    "StatusPollCyclePause"=dword:05 ; Status register DRQ/BSY polling; 5 milliseconds between poll cycles
    "SpawnFunction"="CreatePCMCIA"  ; controller-specific instantiation function
    "IsrDll"="giisr.dll"            ; bus-agnostic; installable ISR
    "IsrHandler"="ISRHandler"       ; bus-agnostic; installable ISR
    "DeviceControlOffset"=dword:0   ; AT task file offset of device control I/O port
    "AlternateStatusOffset"=dword:0 ; AT task file offset of alternate status I/O port
    "RegisterStride"=dword:01       ; AT task file register stride; register block is contiguous
[HKEY_LOCAL_MACHINE\Drivers\PCCARD\PCMCIA\TEMPLATE\ATADISKA\Device0]
    "IClass"=multi_sz:"{A4E7EDDA-E575-4252-9D6B-4195D48BB865}"
    "Prefix"="DSK"
    "Dll"="atapi.dll"
    "InterruptDriven"=dword:00      ; interrupt driven I/O {0=disable, 1=enable}
    "DMA"=dword:00                  ; DMA {0=disable, 1=enable}
    "DoubleBufferSize"=dword:10000  ; double buffer size (bytes); should be larger than DRQ data block {0=disabled, ..., 131072}
    "DrqDataBlockSize"=dword:200    ; sector-aligned DRQ data block size (bytes), i.e., R/W Multiple sectors/interrupt {0=device default, 512, ..., 130560}
    "WriteCache"=dword:01           ; write cache {0=disable, 1=enable}
    "LookAhead"=dword:01            ; lookahead {0=disable, 1=enable}
    "DeviceId"=dword:00             ; device 0, i.e., primary master
    "TransferMode"=dword:FF         ; transfer mode (Ultra DMA 3, 4 require 80-conductor cable); see TransferMode Key
[HKEY_LOCAL_MACHINE\Drivers\PCCARD\PCMCIA\TEMPLATE\ATADISKB]
    "FUNCTION_ID"=dword:4
    "IoBase"=multi_sz:"170","376"
    "IoLen"=multi_sz:"8","2"
    "IOADDR_HIGHESTBIT_SET"=dword:1
    "Prefix"="IDE"
    "Dll"="atapi.dll"
    "Order"=dword:6
    "Legacy"=dword:00
;   "Irq"=dword:00
;   "SysIntr"=dword:00
;   "DMAAlignment"=dword:00
    "SoftResetTimeout"=dword:03
    "StatusPollCycles"=dword:100
    "StatusPollsPerCycle"=dword:20
    "StatusPollCyclePause"=dword:05
    "SpawnFunction"="CreatePCMCIA"
    "IsrDll"="giisr.dll"
    "IsrHandler"="ISRHandler"
    "DeviceControlOffset"=dword:0
    "AlternateStatusOffset"=dword:0
    "RegisterStride"=dword:01
[HKEY_LOCAL_MACHINE\Drivers\PCCARD\PCMCIA\TEMPLATE\ATADISKB\Device0]
    "IClass"=multi_sz:"{A4E7EDDA-E575-4252-9D6B-4195D48BB865}"
    "Prefix"="DSK"
    "Dll"="atapi.dll"
    "InterruptDriven"=dword:00
    "DMA"=dword:00
    "DoubleBufferSize"=dword:10000
    "DrqDataBlockSize"=dword:200
    "WriteCache"=dword:01
    "LookAhead"=dword:01
    "DeviceId"=dword:00
    "TransferMode"=dword:FF
; @CESYSGEN ENDIF ATAPI_ATAPI_PCMCIA
