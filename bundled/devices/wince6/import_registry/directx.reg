    "MaxFullFrameRateForward"=dword:00000002
    "MaxFullFrameRateBackward"=dword:00000002
    "MaxSupportedSpeed"=dword:000000FA
;    "EnableFilePreCreation"=dword:00000000
; File sizes below chosen to minimize the impact of a FAT file system
; performance scaling issue related to the size of a file:
    "MaxPermFileSizeCb"=dword:6400000
    "MaxTempFileSizeCb"=dword:6400000
; Alternate values that work well if your file system doesn't have this
; performance scaling issue:
;    "MaxPermFileSizeCb"=dword:FF000000
;    "MaxTempFileSizeCb"=dword:8000000
; Priorities that assume you haven't cranked up the priorities on
; your mpeg source and decoder filters. If you have an application
; eating up CPU too, reduce your thread quantum [e.g. to 5 ms]
; across the board, drop your mpeg source filter priority to something
; like 240 to 248, drop your mepg decoder filter priority to 250,
; and decrease DVRWriterPriority, DVRReaderPriority, and StreamingThreadPri
; to match your mpeg decoder filter priority. It is recommended that you
; also change DVRPreCreatePriority to 252 and both DVRLazyOpenPriority
; and DVRLazyDeletePriority to 251.
    "DVRReaderPriority"=dword:FB		; priority 251
    "DVRWriterPriority"=dword:FA		; priority 250
    "DVRPreCreatePriority"=dword:FD		; priority 253
    "DVRLazyOpenPriority"=dword:FC		; priority 252
    "DVRLazyDeletePriority"=dword:FC	; priority 252
    "StreamingThreadPri"=dword:FB		; priority 251
; Clock tolerances for retail builds should be cranked down to about 0.98 min
; and 1.02 max once you have tuned your system up:
    "DVRMinClockDebug"=dword:1388		; clock slaving ratio 5000/10000 = 0.5000
	"DVRMaxClockDebug"=dword:3A98		; clock slaving ratio 15000/10000 = 1.5000
	"DVRMinClockRetail"=dword:251c		; clock slaving ratio 9500/10000 = 0.9500
	"DVRMaxClockRetail"=dword:2904		; clock slaving ratio 10500/10000 = 1.0500
; @CESYSGEN ENDIF DIRECTX_MODULES_DVRENGINE

