; @CESYSGEN IF DIRECTX_MODULES_NMD_UI

	[HKEY_LOCAL_MACHINE\init]
		"Launch90"="nmd_ui.exe"
		"Depend90"=hex:1E,00, 3C,00

	[HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\DirectShow]
		"SharedMemoryThreshold"=dword:400

	[HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\DirectShow\ThreadPriority]
		"AsyncVideoRenderer"=dword:FA

	;Set max upnp response packet size to 512K
	[HKEY_LOCAL_MACHINE\COMM\UPnP]
		"MaxActionResponse"=dword:80000

	[HKEY_LOCAL_MACHINE\System\ObjectStore\RegFlush]
		"SpawnThread"=dword:1
		"FlushPriority256"=dword:FF
		"ActivityThreshold"=dword:100
		; Timeout period for a flush -- 5 minutes
		"FlushPeriod"=dword:493E0

	[HKEY_LOCAL_MACHINE\COMM\UPnPDevices\MediaRenderer]
; We want the default media renderer to not load, this will allow us to load it in proc when we need it
		"State"=dword:0
; We are also going to overide the default device description document with one that better matches the NMD functionality
		"XMLDescFile"="\\windows\\upnp\\NMDMediaRenderer.xml"

; We want Anti-Aliasing if available
[HKEY_LOCAL_MACHINE\System\GDI\FONTSMOOTHING]
; Just haveing the key is all it takes to turn on AA, no values required

; @CESYSGEN ENDIF DIRECTX_MODULES_NMD_UI

